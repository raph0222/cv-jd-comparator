# LLM
# Default: ollama (local Docker, model qwen2.5:3b). No config needed.
#
# To use Gemini with Google Cloud (Vertex AI) fill in:
# LLM_PROVIDER=gemini-vertex
# LLM_MODEL=gemini-2.5-flash-lite
# GOOGLE_CLOUD_PROJECT=
# GOOGLE_CLOUD_LOCATION=global
# GOOGLE_CREDENTIALS_FILE=$HOME/.config/google/vertex-credentials.json

# Runtime
APP_ENV=development
LOG_LEVEL=INFO
#STRUCTURED_LOGS=true

# Observability
# LANGSMITH_TRACING=true
# LANGSMITH_PROJECT=
# LANGSMITH_API_KEY=
# LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# Security
# MAX_INPUT_LENGTH=50000
RATE_LIMIT=

# CORS
# * for local dev
CORS_ALLOWED_ORIGINS=*