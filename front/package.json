{
  "name": "cv-compare-front",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "run-p lint-check \"build-only {@}\" --",
    "preview": "vite preview",
    "build-only": "vite build",
    "format": "prettier --write src/",
    "format-check": "prettier --check src/",
    "lint": "npm run format && eslint . --ext .vue,.js,.jsx,.ts,.tsx,.cts,.mts --fix --ignore-path ./.eslintignore --max-warnings 0",
    "lint-check": "npm run format-check && eslint . --ext .vue,.js,.jsx,.ts,.tsx,.cts,.mts --ignore-path ./.eslintignore --max-warnings 0"
  },
  "dependencies": {
    "axios": "^1.13.6",
    "vue": "^3.5.18",
    "vuex": "^4.1.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.4",
    "autoprefixer": "^10.4.21",
    "eslint": "^8.57.0",
    "eslint-plugin-vue": "^9.23.0",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.5.6",
    "prettier": "^3.2.5",
    "tailwindcss": "^3.4.17",
    "vite": "^5.4.19"
  }
}
